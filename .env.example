# Copy to `.env` and fill in. `.env` is gitignored — your key never gets committed.
# Both cli.py and `python -m eval.run_eval` auto-load this file at startup.

# --- LLM backend (set ONE) ---
OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o            # optional; default is gpt-4o-mini
# ANTHROPIC_API_KEY=...         # alternative backend (also `pip install anthropic`)

# --- Force a specific run mode (optional) ---
# TRIAGE_MODE=openai            # openai | anthropic | replay. Omit to auto-select.

# --- Live Toolshop instead of fixtures (optional) ---
# API_BASE_URL=http://localhost:8091/api
